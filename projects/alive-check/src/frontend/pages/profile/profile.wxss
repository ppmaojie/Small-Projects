/* 个人中心页面样式 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a1a 0%, #2d2d2d 100%);
  padding: 40rpx;
}

/* 用户信息卡片 */
.profile-card {
  display: flex;
  align-items: center;
  gap: 30rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #333333;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.nickname {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
}

.user-id {
  font-size: 24rpx;
  color: #999999;
}

.edit-btn {
  width: 120rpx;
  height: 60rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  border: none;
}

/* 统计区域 */
.stats-section {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  padding: 40rpx 20rpx;
  margin-bottom: 30rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #FFD700;
}

.stat-label {
  font-size: 24rpx;
  color: #999999;
}

.stat-divider {
  width: 1rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.1);
}

/* 菜单列表 */
.menu-section {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 30rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #ffffff;
}

.menu-arrow {
  font-size: 28rpx;
  color: #999999;
}

/* 退出登录 */
.logout-section {
  margin-top: 60rpx;
}

.logout-btn {
  width: 100%;
  height: 90rpx;
  border-radius: 45rpx;
  font-size: 32rpx;
  background: rgba(255, 71, 87, 0.2);
  color: #ff4757;
  border: 2rpx solid #ff4757;
}

/* 版本信息 */
.version {
  text-align: center;
  margin-top: 40rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.05);
}

.version text {
  font-size: 24rpx;
  color: #666666;
}
