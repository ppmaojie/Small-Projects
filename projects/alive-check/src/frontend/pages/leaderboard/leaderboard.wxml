<!--排行榜页面-->
<view class="container">
  <!-- 页面标题 -->
  <view class="header">
    <text class="title">📊 排行榜</text>
    <text class="subtitle">看看谁最苟</text>
  </view>

  <!-- Tab 切换 -->
  <view class="tabs">
    <view 
      class="tab {{activeTab === item.key ? 'active' : ''}}" 
      wx:for="{{tabs}}" 
      wx:key="key"
      bindtap="switchTab"
      data-type="{{item.key}}">
      {{item.name}}
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 排行榜列表 -->
  <view class="leaderboard-list" wx:if="{{!loading && leaderboards[activeTab].length > 0}}">
    <view class="rank-item" wx:for="{{leaderboards[activeTab]}}" wx:key="user._id">
      <view class="rank">
        <text class="rank-icon">{{item.rank === 1 ? '🥇' : (item.rank === 2 ? '🥈' : (item.rank === 3 ? '🥉' : '#' + item.rank))}}</text>
      </view>
      
      <image class="avatar" src="{{item.user.avatar || '/assets/default-avatar.png'}}" mode="aspectFill" />
      
      <view class="info">
        <text class="nickname">{{item.user.nickname}}</text>
        <text class="unit" wx:if="{{item.unit}}">{{item.unit}}</text>
      </view>
      
      <view class="score">
        <text class="score-value">{{item.score}}</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{!loading && leaderboards[activeTab].length === 0}}">
    <text class="empty-icon">📭</text>
    <text class="empty-text">暂无数据</text>
  </view>
</view>
