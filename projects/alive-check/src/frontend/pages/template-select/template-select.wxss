/* 模板选择页面样式 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a1a 0%, #2d2d2d 100%);
  padding: 40rpx;
  padding-bottom: 200rpx;
}

/* 头部 */
.header {
  text-align: center;
  margin-bottom: 30rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
}

.subtitle {
  font-size: 28rpx;
  color: #999999;
  margin-top: 10rpx;
  display: block;
}

/* 分类 Tab */
.category-tabs {
  display: flex;
  gap: 10rpx;
  margin-bottom: 30rpx;
  overflow-x: auto;
  padding: 10rpx 0;
}

.tab {
  flex-shrink: 0;
  padding: 16rpx 32rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 30rpx;
  font-size: 28rpx;
  color: #999999;
  transition: all 0.3s;
}

.tab.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  font-weight: bold;
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999999;
}

/* 模板列表 */
.template-list {
  height: calc(100vh - 400rpx);
}

.template-item {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.template-item.selected {
  border-color: #667eea;
  background: rgba(102, 126, 234, 0.1);
}

.template-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.template-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
}

.template-category {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #ffffff;
}

.template-preview {
  font-size: 28rpx;
  color: #cccccc;
  line-height: 1.6;
  margin-bottom: 20rpx;
  padding: 20rpx;
  background: rgba(0, 0, 0, 0.2);
  border-radius: 10rpx;
}

.template-actions {
  display: flex;
  justify-content: flex-end;
}

.preview-btn {
  padding: 10rpx 30rpx;
  font-size: 24rpx;
  background: rgba(255, 255, 255, 0.1);
  color: #ffffff;
  border-radius: 20rpx;
  border: none;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  gap: 20rpx;
}

.empty-icon {
  font-size: 120rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

/* 底部确认按钮 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30rpx;
  background: linear-gradient(180deg, transparent 0%, rgba(26, 26, 26, 1) 100%);
}

.confirm-btn {
  width: 100%;
  height: 100rpx;
  border-radius: 50rpx;
  font-size: 36rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  border: none;
  box-shadow: 0 10rpx 30rpx rgba(102, 126, 234, 0.4);
}
